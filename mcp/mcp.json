{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "C:\\"],
      "description": "Access and manage files on your system",
      "disabled": false,
      "autoApprove": [
        "read_file",
        "list_directory"
      ]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "Persistent memory storage across conversations",
      "disabled": false,
      "autoApprove": [
        "create_entities",
        "create_relations",
        "add_observations"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Enhanced reasoning and problem-solving capabilities",
      "disabled": false,
      "autoApprove": []
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      },
      "description": "Interact with GitHub repositories, issues, and PRs",
      "disabled": true,
      "autoApprove": []
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://localhost/mydb"],
      "description": "Query and manage PostgreSQL databases",
      "disabled": true,
      "autoApprove": []
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": ""
      },
      "description": "Search the web using Brave Search API",
      "disabled": true,
      "autoApprove": []
    },
    "google-maps": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-maps"],
      "env": {
        "GOOGLE_MAPS_API_KEY": ""
      },
      "description": "Access Google Maps data and geocoding",
      "disabled": true,
      "autoApprove": []
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "",
        "SLACK_TEAM_ID": ""
      },
      "description": "Send messages and interact with Slack",
      "disabled": true,
      "autoApprove": []
    },
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "description": "Browser automation and web scraping",
      "disabled": true,
      "autoApprove": []
    },
    "aws-kb-retrieval": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-aws-kb-retrieval"],
      "env": {
        "AWS_ACCESS_KEY_ID": "",
        "AWS_SECRET_ACCESS_KEY": "",
        "AWS_REGION": "us-east-1"
      },
      "description": "Retrieve information from AWS Knowledge Base",
      "disabled": true,
      "autoApprove": []
    },
    "sqlite": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db-path", "database.db"],
      "description": "Query and manage SQLite databases",
      "disabled": true,
      "autoApprove": []
    },
    "docker": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-docker"],
      "description": "Manage Docker containers and images",
      "disabled": true,
      "autoApprove": []
    },
    "kubernetes": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-kubernetes"],
      "description": "Interact with Kubernetes clusters",
      "disabled": true,
      "autoApprove": []
    },
    "git": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git"],
      "description": "Git repository operations",
      "disabled": true,
      "autoApprove": []
    },
    "sentry": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sentry"],
      "env": {
        "SENTRY_AUTH_TOKEN": "",
        "SENTRY_ORG": "",
        "SENTRY_PROJECT": ""
      },
      "description": "Monitor and debug errors with Sentry",
      "disabled": true,
      "autoApprove": []
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "description": "Fetch and process web content",
      "disabled": true,
      "autoApprove": []
    },
    "everart": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everart"],
      "env": {
        "EVERART_API_KEY": ""
      },
      "description": "AI image generation with EverArt",
      "disabled": true,
      "autoApprove": []
    }
  }
}
